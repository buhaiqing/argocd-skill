# ArgoCD 凭证配置
# 优先级：ARGOCD_AUTH_TOKEN > ARGOCD_USERNAME + ARGOCD_PASSWORD

# ── 方式一：Token（推荐自动化 / CI/CD 场景）──────────────────────────
# 从 argocd account generate-token 获取
ARGOCD_AUTH_TOKEN=

# ── 方式二：用户名 + 密码（备用，ARGOCD_AUTH_TOKEN 未设时使用）─────────
# ARGOCD_USERNAME=
# ARGOCD_PASSWORD=

# ── 通用配置 ─────────────────────────────────────────────────────────
# ArgoCD 服务地址（支持带 context path 的完整 base URL）
ARGOCD_SERVER=https://argocd.hd123.com/dnet-int

# ArgoCD CLI 版本（可选，不设则自动拉取最新版）
# ARGOCD_VERSION=v3.4.2

# ── 可观测与自进化（P3.5）────────────────────────────────────────────
# 轨迹 / 离线分析存储根目录（可选；不设则默认 <repo>/.runtime/argocd-skill）
# 支持相对路径，相对 skill 仓库根解析（与启动 cwd 无关），例如：
# ARGOCD_SKILL_RUNTIME_DIR=.runtime/argocd-skill
# ARGOCD_SKILL_RUNTIME_DIR=./runtime/argocd-skill
# 会话轨迹：$ARGOCD_SKILL_RUNTIME_DIR/sessions/{session_id}/trace_*.jsonl

# 会话结束时自动跑轻量分析（1/true/yes 启用；默认关闭，仅 dry-run 不写回）
# ARGOCD_SKILL_SESSION_HOOK=1