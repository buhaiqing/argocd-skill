# ArgoCD 凭证配置
# 优先级：ARGOCD_AUTH_TOKEN > ARGOCD_USERNAME + ARGOCD_PASSWORD

# ── 方式一：Token（推荐自动化 / CI/CD 场景）──────────────────────────
# 从 argocd account generate-token 获取
ARGOCD_AUTH_TOKEN=

# ── 方式二：用户名 + 密码（备用，ARGOCD_AUTH_TOKEN 未设时使用）─────────
# ARGOCD_USERNAME=
# ARGOCD_PASSWORD=

# ── 通用配置 ─────────────────────────────────────────────────────────
# ArgoCD 服务地址（支持带 context path 的完整 base URL）
ARGOCD_SERVER=https://argocd.hd123.com/dnet-int

# ArgoCD CLI 版本（可选，不设则自动拉取最新版）
# ARGOCD_VERSION=v3.4.2